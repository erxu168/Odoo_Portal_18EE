<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_bill_tree_coin" model="ir.ui.view">
        <field name="name">pos.bill.list.coin</field>
        <field name="model">pos.bill</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_bill_tree"/>
        <field name="arch" type="xml">
            <field name="value" position="after">
                <field name="is_coin"/>
            </field>
        </field>
    </record>

    <record id="view_pos_bill_form_coin" model="ir.ui.view">
        <field name="name">pos.bill.form.coin</field>
        <field name="model">pos.bill</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_bill_form"/>
        <field name="arch" type="xml">
            <field name="value" position="after">
                <field name="is_coin"/>
            </field>
        </field>
    </record>
</odoo>
