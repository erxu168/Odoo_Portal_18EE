<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            Krawings letterhead v5 - table-based layout for wkhtmltopdf.

            wkhtmltopdf uses an ancient WebKit engine that does NOT
            support CSS flexbox. All layouts use HTML tables instead.
        -->

        <!-- ============================================== -->
        <!-- Override DIN 5008 HEADER                        -->
        <!-- ============================================== -->
        <template id="kw_din5008_header"
                  inherit_id="l10n_din5008.external_layout_din5008"
                  name="Krawings Header">

            <xpath expr="//table[hasclass('company_header')]" position="replace">
                <table style="width: 100%; border-collapse: collapse; margin-bottom: 3mm;">
                    <tr>
                        <td style="vertical-align: top;">
                            <div t-field="company.name"
                                 style="font-size: 20pt; font-weight: bold; letter-spacing: -0.02em; line-height: 1.15; color: #1a1a1a;"/>
                            <div t-if="company.report_header"
                                 style="font-size: 7pt; color: #999; letter-spacing: 0.1em; text-transform: uppercase; margin-top: 2px;">
                                <t t-out="company.report_header"/>
                            </div>
                        </td>
                        <td t-if="company.logo" style="vertical-align: top; text-align: right; width: 50mm;">
                            <img t-att-src="image_data_uri(company.logo)"
                                 style="max-height: 20mm; max-width: 48mm;"
                                 alt="Logo"/>
                        </td>
                    </tr>
                </table>
                <div style="border-top: 1px solid #1a1a1a; margin-bottom: 2mm;"/>
            </xpath>

        </template>


        <!-- ============================================== -->
        <!-- Override DIN 5008 FOOTER                        -->
        <!-- ============================================== -->
        <template id="kw_din5008_footer"
                  inherit_id="l10n_din5008.external_layout_din5008"
                  name="Krawings Footer">

            <xpath expr="//div[hasclass('company_details')]" position="replace">
                <div style="border-top: 1px solid #1a1a1a; padding-top: 2mm;">
                    <table style="width: 100%; border-collapse: collapse; font-size: 6pt; line-height: 1.6; color: #1a1a1a;">
                        <tr style="vertical-align: top;">

                            <!-- Column: Kontakt (always) -->
                            <td style="padding-right: 3mm; border-right: 1px solid #e0e0e0;">
                                <div style="font-size: 5pt; font-weight: bold; letter-spacing: 0.1em; text-transform: uppercase; color: #999; margin-bottom: 1mm;">KONTAKT</div>
                                <span t-field="company.name"/><br/>
                                <t t-if="company.street"><span t-field="company.street"/><br/></t>
                                <t t-if="company.street2"><span t-field="company.street2"/><br/></t>
                                <t t-if="company.zip or company.city">
                                    <t t-if="company.zip"><span t-field="company.zip"/> </t>
                                    <t t-if="company.city"><span t-field="company.city"/></t>
                                    <br/>
                                </t>
                                <t t-if="company.phone">Tel: <span t-field="company.phone"/><br/></t>
                                <t t-if="company.mobile and not company.phone">Tel: <span t-field="company.mobile"/><br/></t>
                                <t t-if="company.email"><span t-field="company.email"/></t>
                            </td>

                            <!-- Column: Handelsregister (only if data exists) -->
                            <t t-if="company.company_registry or company.company_details">
                                <td style="padding-left: 3mm; padding-right: 3mm; border-right: 1px solid #e0e0e0;">
                                    <div style="font-size: 5pt; font-weight: bold; letter-spacing: 0.1em; text-transform: uppercase; color: #999; margin-bottom: 1mm;">HANDELSREGISTER</div>
                                    <t t-if="company.company_details"><span t-field="company.company_details"/><br/></t>
                                    <t t-if="company.company_registry"><span t-field="company.company_registry"/></t>
                                </td>
                            </t>

                            <!-- Column: Bank (only if bank accounts exist) -->
                            <t t-if="company.partner_id.bank_ids">
                                <td style="padding-left: 3mm; padding-right: 3mm; border-right: 1px solid #e0e0e0;">
                                    <div style="font-size: 5pt; font-weight: bold; letter-spacing: 0.1em; text-transform: uppercase; color: #999; margin-bottom: 1mm;">BANKVERBINDUNG</div>
                                    <t t-set="bank" t-value="company.partner_id.bank_ids[0]"/>
                                    <t t-if="bank.bank_id.name"><span t-out="bank.bank_id.name"/><br/></t>
                                    <t t-if="bank.bank_name and not bank.bank_id.name"><span t-out="bank.bank_name"/><br/></t>
                                    <t t-if="bank.acc_number">IBAN: <span t-out="bank.acc_number"/><br/></t>
                                    <t t-if="bank.bank_id.bic">BIC: <span t-out="bank.bank_id.bic"/></t>
                                    <t t-if="bank.bank_bic and not bank.bank_id.bic">BIC: <span t-out="bank.bank_bic"/></t>
                                </td>
                            </t>

                            <!-- Column: Tax (only if VAT exists) -->
                            <t t-if="company.vat">
                                <td style="padding-left: 3mm;">
                                    <div style="font-size: 5pt; font-weight: bold; letter-spacing: 0.1em; text-transform: uppercase; color: #999; margin-bottom: 1mm;">STEUERDATEN</div>
                                    <t t-out="company.account_fiscal_country_id.vat_label or 'USt-IdNr.'"/>:
                                    <span t-if="forced_vat" t-out="forced_vat"/>
                                    <span t-else="" t-field="company.vat"/>
                                </td>
                            </t>

                        </tr>
                    </table>
                </div>
            </xpath>

            <!-- Replace page number -->
            <xpath expr="//div[hasclass('page_number')]" position="replace">
                <div style="text-align: right; font-size: 6pt; color: #999; margin-top: 1mm;">
                    Seite <span class="page"/> von <span class="topage"/>
                </div>
            </xpath>

        </template>

    </data>
</odoo>
