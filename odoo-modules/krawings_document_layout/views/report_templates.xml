<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            Krawings letterhead via background image.

            Each company has a custom PNG letterhead uploaded as
            layout_background_image with layout_background = "Custom".
            The background contains the header (company name, accent bar)
            and footer (Kontakt, Handelsregister, Bank, Steuerdaten).

            This module hides the DIN 5008 header and footer content
            so they don't render on top of the background image.
            The address block and document info in the body remain
            since those are dynamic per-document.
        -->

        <!-- Hide DIN 5008 header content (background has it) -->
        <template id="kw_hide_header"
                  inherit_id="l10n_din5008.external_layout_din5008"
                  name="Krawings: hide header content">
            <xpath expr="//table[hasclass('company_header')]" position="replace">
                <!-- Empty: letterhead background has the header -->
                <div style="height: 15mm;"/>
            </xpath>
        </template>

        <!-- Hide DIN 5008 footer content (background has it) -->
        <template id="kw_hide_footer"
                  inherit_id="l10n_din5008.external_layout_din5008"
                  name="Krawings: hide footer content">
            <xpath expr="//div[hasclass('company_details')]" position="replace">
                <!-- Empty: letterhead background has the footer -->
                <div/>
            </xpath>
            <xpath expr="//div[hasclass('page_number')]" position="replace">
                <div/>
            </xpath>
        </template>

    </data>
</odoo>
