<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_applicant_form_inherit_krawings_recruitment" model="ir.ui.view">
        <field name="name">hr.applicant.form.inherit.krawings.recruitment</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(krawings_recruitment.action_grant_portal_access_wizard)d"
                        string="Grant Portal Access"
                        type="action"
                        icon="fa-key"
                        class="oe_stat_button"/>
                <button name="%(krawings_recruitment.action_create_employee_wizard)d"
                        string="Create Employee"
                        type="action"
                        icon="fa-user-plus"
                        class="oe_stat_button"/>
            </xpath>
        </field>
    </record>
</odoo>
