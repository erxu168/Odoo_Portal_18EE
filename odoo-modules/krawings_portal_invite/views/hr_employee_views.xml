<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_portal_invite" model="ir.ui.view">
        <field name="name">hr.employee.form.portal.invite</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_send_portal_invite"
                        type="object"
                        string="Send portal invite"
                        class="btn-primary"
                        confirm="Send a portal invite to this employee now? They will get a link to set up their account."/>
            </xpath>
        </field>
    </record>
</odoo>
