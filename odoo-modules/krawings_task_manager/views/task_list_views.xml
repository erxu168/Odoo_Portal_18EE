<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_krawings_task_list_tree" model="ir.ui.view">
        <field name="name">krawings.task.list.tree</field>
        <field name="model">krawings.task.list</field>
        <field name="arch" type="xml">
            <list string="Daily Task Lists" decoration-success="state == 'done'" decoration-warning="overdue_count > 0">
                <field name="date"/>
                <field name="department_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="completion_rate" widget="progressbar"/>
                <field name="line_count"/>
                <field name="overdue_count"/>
                <field name="photo_pending_count"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_krawings_task_list_form" model="ir.ui.view">
        <field name="name">krawings.task.list.form</field>
        <field name="model">krawings.task.list</field>
        <field name="arch" type="xml">
            <form string="Daily Task List">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="department_id"/> — <field name="date"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="template_id"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="completion_rate" widget="progressbar"/>
                            <field name="overdue_count"/>
                            <field name="photo_pending_count"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <list>
                            <field name="day_part"/>
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="deadline_datetime"/>
                            <field name="state"/>
                            <field name="completed_at"/>
                            <field name="completed_by_name"/>
                            <field name="photo_required"/>
                            <field name="photo_uploaded"/>
                            <field name="is_ad_hoc" string="Ad-hoc"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_krawings_task_list" model="ir.actions.act_window">
        <field name="name">Daily Task Lists</field>
        <field name="res_model">krawings.task.list</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_today': 1}</field>
    </record>

    <record id="view_krawings_task_list_search" model="ir.ui.view">
        <field name="name">krawings.task.list.search</field>
        <field name="model">krawings.task.list</field>
        <field name="arch" type="xml">
            <search>
                <field name="department_id"/>
                <field name="date"/>
                <filter string="Today" name="filter_today" domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="This Week" name="filter_week" domain="[('date', '&gt;=', (context_today() - relativedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Department" name="group_dept" context="{'group_by': 'department_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
