<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_krawings_task_template_tree" model="ir.ui.view">
        <field name="name">krawings.task.template.tree</field>
        <field name="model">krawings.task.template</field>
        <field name="arch" type="xml">
            <list string="Task Templates">
                <field name="name"/>
                <field name="department_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="day_mon" string="Mo"/>
                <field name="day_tue" string="Tu"/>
                <field name="day_wed" string="We"/>
                <field name="day_thu" string="Th"/>
                <field name="day_fri" string="Fr"/>
                <field name="day_sat" string="Sa"/>
                <field name="day_sun" string="Su"/>
                <field name="line_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_krawings_task_template_form" model="ir.ui.view">
        <field name="name">krawings.task.template.form</field>
        <field name="model">krawings.task.template</field>
        <field name="arch" type="xml">
            <form string="Task Template">
                <header>
                    <button name="action_spawn_today" type="object" string="Spawn Today" class="btn-primary"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Kitchen — Standard Day"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="department_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Days of Week">
                            <field name="day_mon"/>
                            <field name="day_tue"/>
                            <field name="day_wed"/>
                            <field name="day_thu"/>
                            <field name="day_fri"/>
                            <field name="day_sat"/>
                            <field name="day_sun"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Tasks">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="day_part"/>
                                    <field name="name"/>
                                    <field name="deadline_time" widget="float_time"/>
                                    <field name="photo_required" widget="boolean_toggle"/>
                                    <field name="module_link_type"/>
                                </list>
                                <form>
                                    <group>
                                        <field name="name"/>
                                        <field name="day_part"/>
                                        <field name="sequence"/>
                                        <field name="deadline_time" widget="float_time"/>
                                        <field name="photo_required"/>
                                        <field name="module_link_type"/>
                                    </group>
                                    <separator string="Subtasks"/>
                                    <field name="subtask_ids">
                                        <list editable="bottom">
                                            <field name="sequence" widget="handle"/>
                                            <field name="name"/>
                                        </list>
                                    </field>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_krawings_task_template" model="ir.actions.act_window">
        <field name="name">Task Templates</field>
        <field name="res_model">krawings.task.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
