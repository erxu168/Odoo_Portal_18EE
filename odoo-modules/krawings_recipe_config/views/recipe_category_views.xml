<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_recipe_category_list" model="ir.ui.view">
        <field name="name">krawings.recipe.category.list</field>
        <field name="model">krawings.recipe.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="icon"/>
                <field name="name"/>
                <field name="mode"/>
                <field name="warehouse_ids" widget="many2many_tags"/>
                <field name="recipe_count"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_recipe_category_form" model="ir.ui.view">
        <field name="name">krawings.recipe.category.form</field>
        <field name="model">krawings.recipe.category</field>
        <field name="arch" type="xml">
            <form string="Recipe Category">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="icon" placeholder="e.g. fire, star"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="mode"/>
                            <field name="warehouse_ids" widget="many2many_tags"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_recipe_category" model="ir.actions.act_window">
        <field name="name">Recipe Categories</field>
        <field name="res_model">krawings.recipe.category</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
