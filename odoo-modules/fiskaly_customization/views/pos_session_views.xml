<?xml version="1.0" encoding="utf-8"?>
<odoo> 
    <record id="view_pos_session_form2" model="ir.ui.view">
        <field name="name">pos.session.form2</field>
        <field name="model">pos.session</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_session_form"></field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='stop_at']" position="after">
                <field name="alternate_session_id" groups="base.group_no_one"/>
            </xpath>
        </field>
    </record>
</odoo>
