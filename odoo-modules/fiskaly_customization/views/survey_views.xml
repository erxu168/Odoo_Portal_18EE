<?xml version="1.0" encoding="utf-8"?>
<odoo> 
    <record id="survey_question_form" model="ir.ui.view">
        <field name="name">survey.question.form.fiskaly.customization</field>
        <field name="model">survey.question</field>
        <field name="inherit_id" ref="survey.survey_question_form"></field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='suggested_answer_ids']//field[@name='value']" position="before">
                <field name="payment_type" column_invisible="parent.dynamic_field_type!='payment_type'"/>
                <field name="receipt_type" column_invisible="parent.dynamic_field_type!='receipt_type'"/>
            </xpath>
        </field>
    </record>
</odoo>
