<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Seed locations matching Odoo 19 CE data -->
        <record id="location_burgherrenstrasse" model="krawings.contract.location">
            <field name="name">Burgherrenstrasse</field>
            <field name="code">BHS</field>
        </record>
        <record id="location_ssk96" model="krawings.contract.location">
            <field name="name">SSK96</field>
            <field name="code">SSK96</field>
        </record>
        <record id="location_gbm38" model="krawings.contract.location">
            <field name="name">GBM38</field>
            <field name="code">GBM38</field>
        </record>
        <record id="location_ck" model="krawings.contract.location">
            <field name="name">CK</field>
            <field name="code">CK</field>
        </record>
        <record id="location_landsberger" model="krawings.contract.location">
            <field name="name">Landsberger Allee</field>
            <field name="code">LA</field>
        </record>
        <record id="location_graberstrasse" model="krawings.contract.location">
            <field name="name">Graberstrasse</field>
            <field name="code">GS</field>
        </record>

        <!-- Cron job: check termination alerts daily -->
        <record id="cron_contract_termination_alerts" model="ir.cron">
            <field name="name">Contracts: Check Kuendigungsfrist Alerts</field>
            <field name="model_id" ref="model_krawings_contract"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_termination_alerts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
