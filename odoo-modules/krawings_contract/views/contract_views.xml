<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════ -->
    <!-- Contract: List View               -->
    <!-- ══════════════════════════════════ -->
    <record id="view_krawings_contract_list" model="ir.ui.view">
        <field name="name">krawings.contract.list</field>
        <field name="model">krawings.contract</field>
        <field name="arch" type="xml">
            <list string="Contracts" default_order="termination_deadline asc"
                  decoration-danger="status == 'expired'"
                  decoration-warning="status == 'expiring'">
                <field name="name"/>
                <field name="contract_type"/>
                <field name="location_id"/>
                <field name="provider_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="premium_amount" string="Premium"/>
                <field name="premium_frequency"/>
                <field name="termination_deadline"/>
                <field name="auto_renewal"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-warning="status == 'expiring'"
                       decoration-danger="status == 'expired'"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════ -->
    <!-- Contract: Form View               -->
    <!-- ══════════════════════════════════ -->
    <record id="view_krawings_contract_form" model="ir.ui.view">
        <field name="name">krawings.contract.form</field>
        <field name="model">krawings.contract</field>
        <field name="arch" type="xml">
            <form string="Contract">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="active,expiring,expired"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Contract Name"/></h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="contract_type"/>
                            <field name="location_id"/>
                            <field name="provider_id"/>
                            <field name="contract_number"/>
                            <field name="customer_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Dates">
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <label for="kuendigungsfrist_value" string="Kuendigungsfrist"/>
                            <div class="o_row">
                                <field name="kuendigungsfrist_value" class="oe_inline"/>
                                <field name="kuendigungsfrist_unit" class="oe_inline"/>
                            </div>
                            <field name="termination_deadline"/>
                            <field name="auto_renewal"/>
                            <field name="renewal_period_months"
                                   invisible="not auto_renewal"/>
                        </group>
                    </group>
                    <group>
                        <group string="Financial">
                            <field name="premium_amount"/>
                            <field name="premium_frequency"/>
                            <field name="currency_id"/>
                            <field name="annual_cost"/>
                        </group>
                        <group string="Portal Access">
                            <field name="portal_link" widget="url"/>
                            <field name="portal_login"/>
                            <field name="portal_password" password="True"/>
                        </group>
                    </group>

                    <!-- Type-specific: Rent -->
                    <group string="Rent Details"
                           invisible="contract_type != 'rent'">
                        <group>
                            <field name="monthly_rent"/>
                            <field name="maintenance_fee"/>
                            <field name="total_rent"/>
                        </group>
                        <group>
                            <field name="landlord_id"/>
                        </group>
                    </group>

                    <!-- Type-specific: Electricity / Gas -->
                    <group string="Meter Details"
                           invisible="contract_type not in ('electricity', 'gas')">
                        <group>
                            <field name="meter_id"/>
                            <field name="kw_unit_cost"/>
                        </group>
                        <group>
                            <field name="monthly_fee"/>
                            <field name="monthly_installment"/>
                            <field name="verification_code"/>
                        </group>
                    </group>

                    <!-- Type-specific: Insurance -->
                    <group string="Insurance Details"
                           invisible="contract_type != 'insurance'">
                        <group>
                            <field name="insurance_type"/>
                            <field name="insurance_id_number"/>
                        </group>
                    </group>

                    <!-- Type-specific: Telecom -->
                    <group string="Telecom Details"
                           invisible="contract_type != 'telecom'">
                        <group>
                            <field name="phone_numbers"/>
                            <field name="verification_pin"/>
                        </group>
                    </group>

                    <!-- Type-specific: Garbage -->
                    <group string="Garbage / Disposal Details"
                           invisible="contract_type != 'garbage'">
                        <group>
                            <field name="container_size"/>
                            <field name="cost_per_container"/>
                        </group>
                        <group>
                            <field name="pickup_days"/>
                            <field name="service_type"/>
                        </group>
                    </group>

                    <!-- AI Scan Info -->
                    <group string="AI Scan Info"
                           invisible="not ai_scanned">
                        <group>
                            <field name="ai_scanned"/>
                            <field name="ai_confidence"/>
                            <field name="ai_scan_date"/>
                        </group>
                    </group>

                    <group string="Notes">
                        <field name="notes" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════ -->
    <!-- Contract: Search View             -->
    <!-- ══════════════════════════════════ -->
    <record id="view_krawings_contract_search" model="ir.ui.view">
        <field name="name">krawings.contract.search</field>
        <field name="model">krawings.contract</field>
        <field name="arch" type="xml">
            <search string="Search Contracts">
                <field name="name"/>
                <field name="contract_number"/>
                <field name="provider_id"/>
                <field name="location_id"/>
                <separator/>
                <filter name="active_contracts" string="Active"
                        domain="[('status', '=', 'active')]"/>
                <filter name="expiring_contracts" string="Expiring Soon"
                        domain="[('status', '=', 'expiring')]"/>
                <filter name="expired_contracts" string="Expired"
                        domain="[('status', '=', 'expired')]"/>
                <separator/>
                <filter name="type_rent" string="Lease/Rent"
                        domain="[('contract_type', '=', 'rent')]"/>
                <filter name="type_insurance" string="Insurance"
                        domain="[('contract_type', '=', 'insurance')]"/>
                <filter name="type_electricity" string="Electricity"
                        domain="[('contract_type', '=', 'electricity')]"/>
                <filter name="type_gas" string="Gas"
                        domain="[('contract_type', '=', 'gas')]"/>
                <filter name="type_telecom" string="Telecom"
                        domain="[('contract_type', '=', 'telecom')]"/>
                <filter name="type_garbage" string="Garbage"
                        domain="[('contract_type', '=', 'garbage')]"/>
                <filter name="type_service" string="Service"
                        domain="[('contract_type', '=', 'service')]"/>
                <filter name="type_supplier" string="Supplier"
                        domain="[('contract_type', '=', 'supplier')]"/>
                <separator/>
                <filter name="auto_renewal" string="Auto-Renewal"
                        domain="[('auto_renewal', '=', True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_location" string="Location"
                            context="{'group_by': 'location_id'}"/>
                    <filter name="group_type" string="Contract Type"
                            context="{'group_by': 'contract_type'}"/>
                    <filter name="group_status" string="Status"
                            context="{'group_by': 'status'}"/>
                    <filter name="group_provider" string="Provider"
                            context="{'group_by': 'provider_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════ -->
    <!-- Contract: Action                  -->
    <!-- ══════════════════════════════════ -->
    <record id="action_krawings_contract" model="ir.actions.act_window">
        <field name="name">Contracts</field>
        <field name="res_model">krawings.contract</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_krawings_contract_search"/>
        <field name="context">{'search_default_group_location': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No contracts yet. Upload a document in the portal to scan with AI!
            </p>
        </field>
    </record>

</odoo>
