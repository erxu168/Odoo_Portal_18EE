<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Shared letterhead layout -->
    <template id="kw_termination_letterhead">
        <div class="page" style="font-family: Arial, sans-serif; font-size: 11pt; line-height: 1.6; color: #333;">
            <!-- Company logo + address -->
            <div style="margin-bottom: 20px;">
                <img t-if="doc.company_id.logo"
                    t-att-src="image_data_uri(doc.company_id.logo)"
                    style="max-height: 50px; margin-bottom: 10px;"
                    alt="Company Logo"/>
                <div style="font-size: 9pt; color: #666;">
                    <t t-esc="doc.company_id.name"/><br/>
                    <t t-esc="doc.company_id.street"/>
                    <t t-if="doc.company_id.street2">, <t t-esc="doc.company_id.street2"/></t><br/>
                    <t t-esc="doc.company_id.zip"/> <t t-esc="doc.company_id.city"/>
                </div>
            </div>

            <!-- Recipient -->
            <div style="margin-bottom: 30px; min-height: 80px;">
                <t t-esc="doc.employee_name"/><br/>
                <t t-if="doc.employee_street">
                    <t t-esc="doc.employee_street"/><br/>
                    <t t-esc="doc.employee_zip"/> <t t-esc="doc.employee_city"/>
                </t>
                <t t-else="">
                    <span style="color: #c00;">[Adresse fehlt]</span>
                </t>
            </div>

            <!-- Date -->
            <div style="text-align: right; margin-bottom: 20px; font-size: 10pt; color: #666;">
                <t t-esc="doc.company_id.city or 'Berlin'"/>, den <t t-esc="doc.letter_date.strftime('%d.%m.%Y')"/>
            </div>

            <!-- Letter body (injected by each template) -->
            <t t-raw="0"/>

            <!-- Signature block -->
            <div style="margin-top: 50px;">
                Mit freundlichen Gr\u00fc\u00dfen<br/><br/><br/><br/>
                <div style="border-top: 1px solid #999; width: 200px; padding-top: 5px; font-size: 10pt;">
                    Gesch\u00e4ftsf\u00fchrung
                </div>
            </div>
        </div>
    </template>

    <!-- Empfangsbest\u00e4tigung footer (reusable) -->
    <template id="kw_empfangsbestaetigung_footer">
        <div style="margin-top: 50px; padding-top: 15px; border-top: 1px dashed #999; font-size: 10pt; color: #666;">
            <strong>Empfangsbest\u00e4tigung:</strong><br/><br/>
            Ich best\u00e4tige den Erhalt der K\u00fcndigung am ___________<br/><br/><br/><br/>
            <div style="border-top: 1px solid #999; width: 200px; padding-top: 5px;">
                Unterschrift Arbeitnehmer
            </div>
        </div>
    </template>

    <!-- 1. Ordentliche K\u00fcndigung -->
    <template id="report_ordentliche_kuendigung">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-call="krawings_termination.kw_termination_letterhead">
                        <div style="font-weight: bold; font-size: 12pt; margin-bottom: 15px;">
                            K\u00fcndigung Ihres Arbeitsverh\u00e4ltnisses
                        </div>
                        <p>
                            Sehr geehrte/r
                            <t t-if="doc.employee_id.gender == 'male'">Herr</t>
                            <t t-elif="doc.employee_id.gender == 'female'">Frau</t>
                            <t t-else="">Herr/Frau</t>
                            <t t-esc="doc.employee_name.split()[-1] if doc.employee_name else ''"/>,
                        </p>
                        <p>
                            hiermit k\u00fcndigen wir das mit Ihnen bestehende Arbeitsverh\u00e4ltnis
                            ordentlich unter Beachtung der f\u00fcr Sie geltenden K\u00fcndigungsfrist,
                            demzufolge nach unseren Berechnungen zum
                            <strong><t t-esc="doc.last_working_day.strftime('%d.%m.%Y') if doc.last_working_day else '___'"/></strong>,
                            hilfsweise zum n\u00e4chstm\u00f6glichen Zeitpunkt.
                        </p>
                        <p>
                            Nach \u00a7 38 SGB III sind Sie verpflichtet, sich innerhalb von drei Tagen
                            nach Erhalt dieser K\u00fcndigung bei der zust\u00e4ndigen Agentur f\u00fcr Arbeit
                            arbeitssuchend zu melden. Sofern das Arbeitsverh\u00e4ltnis noch l\u00e4nger als
                            drei Monate besteht, ist eine Meldung drei Monate vor der Beendigung
                            ausreichend. Sie sind auch verpflichtet, aktiv nach einer Besch\u00e4ftigung
                            zu suchen. Sollten Sie diesen Verpflichtungen nicht nachkommen, m\u00fcssen Sie
                            mit Nachteilen beim Bezug von Arbeitslosengeld rechnen.
                        </p>
                        <p>
                            Bitte best\u00e4tigen Sie den Erhalt dieses Schreibens auf der beigef\u00fcgten Kopie.
                        </p>
                        <t t-call="krawings_termination.kw_empfangsbestaetigung_footer"/>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <!-- 2. Fristlose K\u00fcndigung -->
    <template id="report_fristlose_kuendigung">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-call="krawings_termination.kw_termination_letterhead">
                        <div style="font-weight: bold; font-size: 12pt; margin-bottom: 15px;">
                            Au\u00dferordentliche fristlose K\u00fcndigung Ihres Arbeitsverh\u00e4ltnisses
                        </div>
                        <p>
                            Sehr geehrte/r
                            <t t-if="doc.employee_id.gender == 'male'">Herr</t>
                            <t t-elif="doc.employee_id.gender == 'female'">Frau</t>
                            <t t-else="">Herr/Frau</t>
                            <t t-esc="doc.employee_name.split()[-1] if doc.employee_name else ''"/>,
                        </p>
                        <p>
                            hiermit k\u00fcndigen wir das mit Ihnen bestehende Arbeitsverh\u00e4ltnis
                            au\u00dferordentlich und fristlos mit sofortiger Wirkung, d.h. mit Zugang
                            dieses Schreibens.
                        </p>
                        <p>
                            Nach \u00a7 38 SGB III sind Sie verpflichtet, sich innerhalb von drei Tagen
                            nach Erhalt dieser K\u00fcndigung bei der zust\u00e4ndigen Agentur f\u00fcr Arbeit
                            arbeitssuchend zu melden. Weiterhin sind Sie verpflichtet, aktiv nach
                            einer Besch\u00e4ftigung zu suchen.
                        </p>
                        <p>
                            Bitte best\u00e4tigen Sie den Erhalt dieses Schreibens auf der beigef\u00fcgten Kopie.
                        </p>
                        <t t-call="krawings_termination.kw_empfangsbestaetigung_footer"/>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <!-- 3. Aufhebungsvertrag -->
    <template id="report_aufhebungsvertrag">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-call="krawings_termination.kw_termination_letterhead">
                        <div style="font-weight: bold; font-size: 12pt; margin-bottom: 15px;">
                            Aufhebungsvertrag
                        </div>

                        <p>zwischen</p>
                        <p style="margin-left: 20px;">
                            <t t-esc="doc.company_id.name"/>,
                            <t t-esc="doc.company_id.street"/>,
                            <t t-esc="doc.company_id.zip"/> <t t-esc="doc.company_id.city"/><br/>
                            - nachfolgend "Arbeitgeber" -
                        </p>
                        <p>und</p>
                        <p style="margin-left: 20px;">
                            <t t-esc="doc.employee_name"/>,
                            <t t-if="doc.employee_street">
                                <t t-esc="doc.employee_street"/>,
                                <t t-esc="doc.employee_zip"/> <t t-esc="doc.employee_city"/>
                            </t><br/>
                            - nachfolgend "Arbeitnehmer" -
                        </p>

                        <p style="font-weight: bold;">\u00a7 1 Beendigung des Arbeitsverh\u00e4ltnisses</p>
                        <p>
                            Die Parteien sind sich dar\u00fcber einig, dass das am
                            <t t-esc="doc.employee_start_date.strftime('%d.%m.%Y') if doc.employee_start_date else '___'"/>
                            begr\u00fcndete Arbeitsverh\u00e4ltnis auf Veranlassung des Arbeitgebers
                            im gegenseitigen Einvernehmen mit Ablauf des
                            <strong><t t-esc="doc.last_working_day.strftime('%d.%m.%Y') if doc.last_working_day else '___'"/></strong>
                            enden wird.
                        </p>

                        <t t-if="doc.garden_leave">
                            <p style="font-weight: bold;">\u00a7 2 Freistellung</p>
                            <p>
                                Der Arbeitnehmer wird ab Unterzeichnung dieses Vertrages
                                unwiderruflich von der Verpflichtung zur Erbringung der Arbeitsleistung
                                unter Fortzahlung der Verg\u00fctung und Anrechnung von Urlaubsanspr\u00fcchen
                                freigestellt.
                            </p>
                        </t>

                        <t t-if="doc.include_severance">
                            <p style="font-weight: bold;">
                                \u00a7 <t t-if="doc.garden_leave">3</t><t t-else="">2</t> Abfindung
                            </p>
                            <p>
                                Der Arbeitgeber zahlt dem Arbeitnehmer f\u00fcr den Verlust des Arbeitsplatzes
                                eine Abfindung in H\u00f6he von
                                <strong><t t-esc="'%.2f' % doc.severance_amount"/> EUR</strong>
                                (brutto). Die Abfindung ist mit der letzten Gehaltsabrechnung f\u00e4llig.
                            </p>
                        </t>

                        <p style="font-weight: bold;">\u00a7 <t t-esc="3 + int(bool(doc.garden_leave)) + int(bool(doc.include_severance))"/> Arbeitszeugnis</p>
                        <p>
                            Der Arbeitgeber erteilt dem Arbeitnehmer unter dem Beendigungsdatum
                            ein wohlwollendes, qualifiziertes Arbeitszeugnis mit einer Dankes-
                            und Bedauernsformel.
                        </p>

                        <p style="font-weight: bold;">\u00a7 <t t-esc="4 + int(bool(doc.garden_leave)) + int(bool(doc.include_severance))"/> Hinweis nach \u00a7 38 SGB III</p>
                        <p>
                            Zur Aufrechterhaltung ungek\u00fcrzter Anspr\u00fcche auf Arbeitslosengeld ist
                            der Arbeitnehmer verpflichtet, sich unverz\u00fcglich nach Abschluss dieses
                            Aufhebungsvertrages pers\u00f6nlich bei der Agentur f\u00fcr Arbeit arbeitssuchend
                            zu melden. Weiterhin ist er verpflichtet, aktiv nach einer Besch\u00e4ftigung
                            zu suchen.
                        </p>

                        <p style="font-weight: bold;">\u00a7 <t t-esc="5 + int(bool(doc.garden_leave)) + int(bool(doc.include_severance))"/> Ausgleichsklausel</p>
                        <p>
                            Mit Erf\u00fcllung dieser Vereinbarung sind s\u00e4mtliche wechselseitigen
                            finanziellen Anspr\u00fcche der Parteien aus dem Arbeitsverh\u00e4ltnis und
                            seiner Beendigung, gleich aus welchem Rechtsgrund, gleich ob bekannt
                            oder unbekannt, abgegolten und erledigt.
                        </p>

                        <!-- Two signature blocks for Aufhebungsvertrag -->
                        <div style="margin-top: 60px; display: flex; justify-content: space-between;">
                            <div>
                                <div style="margin-bottom: 5px; font-size: 10pt; color: #666;">Ort, Datum</div>
                                <div style="border-top: 1px solid #999; width: 200px; padding-top: 5px; font-size: 10pt;">
                                    Unterschrift Arbeitgeber
                                </div>
                            </div>
                            <div>
                                <div style="margin-bottom: 5px; font-size: 10pt; color: #666;">Ort, Datum</div>
                                <div style="border-top: 1px solid #999; width: 200px; padding-top: 5px; font-size: 10pt;">
                                    Unterschrift Arbeitnehmer
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <!-- 4. K\u00fcndigungsbest\u00e4tigung -->
    <template id="report_kuendigungsbestaetigung">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-call="krawings_termination.kw_termination_letterhead">
                        <div style="font-weight: bold; font-size: 12pt; margin-bottom: 15px;">
                            Best\u00e4tigung Ihrer K\u00fcndigung
                        </div>
                        <p>
                            Sehr geehrte/r
                            <t t-if="doc.employee_id.gender == 'male'">Herr</t>
                            <t t-elif="doc.employee_id.gender == 'female'">Frau</t>
                            <t t-else="">Herr/Frau</t>
                            <t t-esc="doc.employee_name.split()[-1] if doc.employee_name else ''"/>,
                        </p>
                        <p>
                            hiermit best\u00e4tigen wir den Erhalt Ihrer K\u00fcndigung vom
                            <t t-esc="doc.resignation_received_date.strftime('%d.%m.%Y') if doc.resignation_received_date else '___'"/>.
                        </p>
                        <p>
                            Unter Ber\u00fccksichtigung der f\u00fcr Sie geltenden K\u00fcndigungsfrist
                            endet Ihr Arbeitsverh\u00e4ltnis mit uns zum
                            <strong><t t-esc="doc.last_working_day.strftime('%d.%m.%Y') if doc.last_working_day else '___'"/></strong>.
                        </p>
                        <p>
                            Wir bitten Sie, alle firmeneigenen Gegenst\u00e4nde, Schl\u00fcssel, Ger\u00e4te
                            und sonstiges Firmeneigentum bis sp\u00e4testens zu Ihrem letzten Arbeitstag
                            zur\u00fcckzugeben.
                        </p>
                        <p>
                            Sie haben Anspruch auf ein wohlwollendes und wahrheitsgem\u00e4\u00dfes
                            Arbeitszeugnis. Bitte teilen Sie uns mit, ob Sie ein einfaches oder
                            qualifiziertes Arbeitszeugnis w\u00fcnschen.
                        </p>
                        <p>
                            Wir m\u00f6chten Sie darauf hinweisen, dass Sie sich gem\u00e4\u00df \u00a7 38 SGB III
                            innerhalb von drei Tagen nach Erhalt dieser Best\u00e4tigung bei der zust\u00e4ndigen
                            Agentur f\u00fcr Arbeit arbeitssuchend melden m\u00fcssen, sofern Sie dies nicht
                            bereits getan haben.
                        </p>
                        <p>
                            F\u00fcr die Zusammenarbeit bedanken wir uns und w\u00fcnschen Ihnen f\u00fcr Ihren
                            weiteren beruflichen und privaten Lebensweg alles Gute.
                        </p>
                    </t>
                </t>
            </t>
        </t>
    </template>
</odoo>
