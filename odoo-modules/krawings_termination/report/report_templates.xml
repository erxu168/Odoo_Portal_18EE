<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Shared letterhead layout -->
    <template id="kw_termination_letterhead">
        <div class="page" style="font-family: Arial, sans-serif; font-size: 11pt; line-height: 1.6; color: #333;">
            <!-- Company logo + address -->
            <div style="margin-bottom: 20px;">
                <img t-if="doc.company_id.logo"
                    t-att-src="image_data_uri(doc.company_id.logo)"
                    style="max-height: 50px; margin-bottom: 10px;"
                    alt="Company Logo"/>
                <div style="font-size: 9pt; color: #666;">
                    <t t-esc="doc.company_id.name"/><br/>
                    <t t-esc="doc.company_id.street"/>
                    <t t-if="doc.company_id.street2">, <t t-esc="doc.company_id.street2"/></t><br/>
                    <t t-esc="doc.company_id.zip"/> <t t-esc="doc.company_id.city"/>
                </div>
            </div>

            <!-- Recipient -->
            <div style="margin-bottom: 30px; min-height: 80px;">
                <t t-esc="doc.employee_name"/><br/>
                <t t-if="doc.employee_street">
                    <t t-esc="doc.employee_street"/><br/>
                    <t t-esc="doc.employee_zip"/> <t t-esc="doc.employee_city"/>
                </t>
                <t t-else="">
                    <span style="color: #c00;">[Adresse fehlt]</span>
                </t>
            </div>

            <!-- Date -->
            <div style="text-align: right; margin-bottom: 20px; font-size: 10pt; color: #666;">
                <t t-esc="doc.company_id.city or 'Berlin'"/>, den <t t-esc="doc.letter_date.strftime('%d.%m.%Y')"/>
            </div>

            <!-- Letter body (injected by each template) -->
            <t t-raw="0"/>

            <!-- Signature block -->
            <div style="margin-top: 50px;">
                Mit freundlichen Gruessen<br/><br/><br/><br/>
                <div style="border-top: 1px solid #999; width: 200px; padding-top: 5px; font-size: 10pt;">
                    Geschaeftsfuehrung
                </div>
            </div>
        </div>
    </template>

    <!-- Empfangsbestaetigung footer (reusable) -->
    <template id="kw_empfangsbestaetigung_footer">
        <div style="margin-top: 50px; padding-top: 15px; border-top: 1px dashed #999; font-size: 10pt; color: #666;">
            <strong>Empfangsbestaetigung:</strong><br/><br/>
            Ich bestaetige den Erhalt der Kuendigung am ___________<br/><br/><br/><br/>
            <div style="border-top: 1px solid #999; width: 200px; padding-top: 5px;">
                Unterschrift Arbeitnehmer
            </div>
        </div>
    </template>

    <!-- 1. Ordentliche Kuendigung -->
    <template id="report_ordentliche_kuendigung">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-call="krawings_termination.kw_termination_letterhead">
                        <div style="font-weight: bold; font-size: 12pt; margin-bottom: 15px;">
                            Kuendigung Ihres Arbeitsverhaeltnisses
                        </div>
                        <p>
                            Sehr geehrte/r
                            <t t-if="doc.employee_id.gender == 'male'">Herr</t>
                            <t t-elif="doc.employee_id.gender == 'female'">Frau</t>
                            <t t-else="">Herr/Frau</t>
                            <t t-esc="doc.employee_name.split()[-1] if doc.employee_name else ''"/>,
                        </p>
                        <p>
                            hiermit kuendigen wir das mit Ihnen bestehende Arbeitsverhaeltnis
                            ordentlich unter Beachtung der fuer Sie geltenden Kuendigungsfrist,
                            demzufolge nach unseren Berechnungen zum
                            <strong><t t-esc="doc.last_working_day.strftime('%d.%m.%Y') if doc.last_working_day else '___'"/></strong>,
                            hilfsweise zum naechstmoeglichen Zeitpunkt.
                        </p>
                        <p>
                            Nach Par. 38 SGB III sind Sie verpflichtet, sich innerhalb von drei Tagen
                            nach Erhalt dieser Kuendigung bei der zustaendigen Agentur fuer Arbeit
                            arbeitssuchend zu melden. Sofern das Arbeitsverhaeltnis noch laenger als
                            drei Monate besteht, ist eine Meldung drei Monate vor der Beendigung
                            ausreichend. Sie sind auch verpflichtet, aktiv nach einer Beschaeftigung
                            zu suchen. Sollten Sie diesen Verpflichtungen nicht nachkommen, muessen Sie
                            mit Nachteilen beim Bezug von Arbeitslosengeld rechnen.
                        </p>
                        <p>
                            Bitte bestaetigen Sie den Erhalt dieses Schreibens auf der beigefuegten Kopie.
                        </p>
                        <t t-call="krawings_termination.kw_empfangsbestaetigung_footer"/>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <!-- 2. Fristlose Kuendigung -->
    <template id="report_fristlose_kuendigung">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-call="krawings_termination.kw_termination_letterhead">
                        <div style="font-weight: bold; font-size: 12pt; margin-bottom: 15px;">
                            Ausserordentliche fristlose Kuendigung Ihres Arbeitsverhaeltnisses
                        </div>
                        <p>
                            Sehr geehrte/r
                            <t t-if="doc.employee_id.gender == 'male'">Herr</t>
                            <t t-elif="doc.employee_id.gender == 'female'">Frau</t>
                            <t t-else="">Herr/Frau</t>
                            <t t-esc="doc.employee_name.split()[-1] if doc.employee_name else ''"/>,
                        </p>
                        <p>
                            hiermit kuendigen wir das mit Ihnen bestehende Arbeitsverhaeltnis
                            ausserordentlich und fristlos mit sofortiger Wirkung, d.h. mit Zugang
                            dieses Schreibens.
                        </p>
                        <p>
                            Nach Par. 38 SGB III sind Sie verpflichtet, sich innerhalb von drei Tagen
                            nach Erhalt dieser Kuendigung bei der zustaendigen Agentur fuer Arbeit
                            arbeitssuchend zu melden. Weiterhin sind Sie verpflichtet, aktiv nach
                            einer Beschaeftigung zu suchen.
                        </p>
                        <p>
                            Bitte bestaetigen Sie den Erhalt dieses Schreibens auf der beigefuegten Kopie.
                        </p>
                        <t t-call="krawings_termination.kw_empfangsbestaetigung_footer"/>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <!-- 3. Aufhebungsvertrag -->
    <template id="report_aufhebungsvertrag">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-call="krawings_termination.kw_termination_letterhead">
                        <div style="font-weight: bold; font-size: 12pt; margin-bottom: 15px;">
                            Aufhebungsvertrag
                        </div>

                        <p>zwischen</p>
                        <p style="margin-left: 20px;">
                            <t t-esc="doc.company_id.name"/>,
                            <t t-esc="doc.company_id.street"/>,
                            <t t-esc="doc.company_id.zip"/> <t t-esc="doc.company_id.city"/><br/>
                            - nachfolgend "Arbeitgeber" -
                        </p>
                        <p>und</p>
                        <p style="margin-left: 20px;">
                            <t t-esc="doc.employee_name"/>,
                            <t t-if="doc.employee_street">
                                <t t-esc="doc.employee_street"/>,
                                <t t-esc="doc.employee_zip"/> <t t-esc="doc.employee_city"/>
                            </t><br/>
                            - nachfolgend "Arbeitnehmer" -
                        </p>

                        <p style="font-weight: bold;">Par. 1 Beendigung des Arbeitsverhaeltnisses</p>
                        <p>
                            Die Parteien sind sich darueber einig, dass das am
                            <t t-esc="doc.employee_start_date.strftime('%d.%m.%Y') if doc.employee_start_date else '___'"/>
                            begruendete Arbeitsverhaeltnis auf Veranlassung des Arbeitgebers
                            im gegenseitigen Einvernehmen mit Ablauf des
                            <strong><t t-esc="doc.last_working_day.strftime('%d.%m.%Y') if doc.last_working_day else '___'"/></strong>
                            enden wird.
                        </p>

                        <t t-if="doc.garden_leave">
                            <p style="font-weight: bold;">Par. 2 Freistellung</p>
                            <p>
                                Der Arbeitnehmer wird ab Unterzeichnung dieses Vertrages
                                unwiderruflich von der Verpflichtung zur Erbringung der Arbeitsleistung
                                unter Fortzahlung der Verguetung und Anrechnung von Urlaubsanspruechen
                                freigestellt.
                            </p>
                        </t>

                        <t t-if="doc.include_severance">
                            <p style="font-weight: bold;">
                                Par. <t t-if="doc.garden_leave">3</t><t t-else="">2</t> Abfindung
                            </p>
                            <p>
                                Der Arbeitgeber zahlt dem Arbeitnehmer fuer den Verlust des Arbeitsplatzes
                                eine Abfindung in Hoehe von
                                <strong><t t-esc="'%.2f' % doc.severance_amount"/> EUR</strong>
                                (brutto). Die Abfindung ist mit der letzten Gehaltsabrechnung faellig.
                            </p>
                        </t>

                        <p style="font-weight: bold;">Par. <t t-esc="3 + int(bool(doc.garden_leave)) + int(bool(doc.include_severance))"/> Arbeitszeugnis</p>
                        <p>
                            Der Arbeitgeber erteilt dem Arbeitnehmer unter dem Beendigungsdatum
                            ein wohlwollendes, qualifiziertes Arbeitszeugnis mit einer Dankes-
                            und Bedauernsformel.
                        </p>

                        <p style="font-weight: bold;">Par. <t t-esc="4 + int(bool(doc.garden_leave)) + int(bool(doc.include_severance))"/> Hinweis nach Par. 38 SGB III</p>
                        <p>
                            Zur Aufrechterhaltung ungekuerzter Ansprueche auf Arbeitslosengeld ist
                            der Arbeitnehmer verpflichtet, sich unverzueglich nach Abschluss dieses
                            Aufhebungsvertrages persoenlich bei der Agentur fuer Arbeit arbeitssuchend
                            zu melden. Weiterhin ist er verpflichtet, aktiv nach einer Beschaeftigung
                            zu suchen.
                        </p>

                        <p style="font-weight: bold;">Par. <t t-esc="5 + int(bool(doc.garden_leave)) + int(bool(doc.include_severance))"/> Ausgleichsklausel</p>
                        <p>
                            Mit Erfuellung dieser Vereinbarung sind saemtliche wechselseitigen
                            finanziellen Ansprueche der Parteien aus dem Arbeitsverhaeltnis und
                            seiner Beendigung, gleich aus welchem Rechtsgrund, gleich ob bekannt
                            oder unbekannt, abgegolten und erledigt.
                        </p>

                        <!-- Two signature blocks for Aufhebungsvertrag -->
                        <div style="margin-top: 60px; display: flex; justify-content: space-between;">
                            <div>
                                <div style="margin-bottom: 5px; font-size: 10pt; color: #666;">Ort, Datum</div>
                                <div style="border-top: 1px solid #999; width: 200px; padding-top: 5px; font-size: 10pt;">
                                    Unterschrift Arbeitgeber
                                </div>
                            </div>
                            <div>
                                <div style="margin-bottom: 5px; font-size: 10pt; color: #666;">Ort, Datum</div>
                                <div style="border-top: 1px solid #999; width: 200px; padding-top: 5px; font-size: 10pt;">
                                    Unterschrift Arbeitnehmer
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <!-- 4. Kuendigungsbestaetigung -->
    <template id="report_kuendigungsbestaetigung">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-call="krawings_termination.kw_termination_letterhead">
                        <div style="font-weight: bold; font-size: 12pt; margin-bottom: 15px;">
                            Bestaetigung Ihrer Kuendigung
                        </div>
                        <p>
                            Sehr geehrte/r
                            <t t-if="doc.employee_id.gender == 'male'">Herr</t>
                            <t t-elif="doc.employee_id.gender == 'female'">Frau</t>
                            <t t-else="">Herr/Frau</t>
                            <t t-esc="doc.employee_name.split()[-1] if doc.employee_name else ''"/>,
                        </p>
                        <p>
                            hiermit bestaetigen wir den Erhalt Ihrer Kuendigung vom
                            <t t-esc="doc.resignation_received_date.strftime('%d.%m.%Y') if doc.resignation_received_date else '___'"/>.
                        </p>
                        <p>
                            Unter Beruecksichtigung der fuer Sie geltenden Kuendigungsfrist
                            endet Ihr Arbeitsverhaeltnis mit uns zum
                            <strong><t t-esc="doc.last_working_day.strftime('%d.%m.%Y') if doc.last_working_day else '___'"/></strong>.
                        </p>
                        <p>
                            Wir bitten Sie, alle firmeneigenen Gegenstaende, Schluessel, Geraete
                            und sonstiges Firmeneigentum bis spaetestens zu Ihrem letzten Arbeitstag
                            zurueckzugeben.
                        </p>
                        <p>
                            Sie haben Anspruch auf ein wohlwollendes und wahrheitsgemaesses
                            Arbeitszeugnis. Bitte teilen Sie uns mit, ob Sie ein einfaches oder
                            qualifiziertes Arbeitszeugnis wuenschen.
                        </p>
                        <p>
                            Wir moechten Sie darauf hinweisen, dass Sie sich gemaess Par. 38 SGB III
                            innerhalb von drei Tagen nach Erhalt dieser Bestaetigung bei der zustaendigen
                            Agentur fuer Arbeit arbeitssuchend melden muessen, sofern Sie dies nicht
                            bereits getan haben.
                        </p>
                        <p>
                            Fuer die Zusammenarbeit bedanken wir uns und wuenschen Ihnen fuer Ihren
                            weiteren beruflichen und privaten Lebensweg alles Gute.
                        </p>
                    </t>
                </t>
            </t>
        </t>
    </template>
</odoo>
