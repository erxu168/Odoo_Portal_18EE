<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="kw_termination_view_list" model="ir.ui.view">
        <field name="name">kw.termination.list</field>
        <field name="model">kw.termination</field>
        <field name="arch" type="xml">
            <list string="Terminations" default_order="letter_date desc">
                <field name="employee_name"/>
                <field name="company_id"/>
                <field name="termination_type"/>
                <field name="letter_date"/>
                <field name="last_working_day"/>
                <field name="delivery_method"/>
                <field name="delivery_confirmed" widget="boolean"/>
                <field name="state" widget="badge"
                    decoration-success="state in ('signed', 'delivered')"
                    decoration-warning="state == 'draft'"
                    decoration-info="state == 'confirmed'"
                    decoration-muted="state in ('archived', 'cancelled')"/>
                <field name="sent_to_accountant" widget="boolean"/>
            </list>
        </field>
    </record>

    <record id="kw_termination_view_form" model="ir.ui.view">
        <field name="name">kw.termination.form</field>
        <field name="model">kw.termination</field>
        <field name="arch" type="xml">
            <form string="Termination">
                <header>
                    <button name="action_confirm" string="Confirm and Generate PDF"
                        type="object" class="oe_highlight"
                        invisible="state != 'draft'"/>
                    <button name="action_sign" string="Sign (Employer)"
                        type="object" class="btn-primary"
                        invisible="state != 'confirmed'"/>
                    <button name="action_check_sign_status" string="Check Sign Status"
                        type="object"
                        invisible="state != 'confirmed' or not sign_request_id"/>
                    <button name="action_mark_delivered" string="Mark as Delivered"
                        type="object" class="btn-primary"
                        invisible="state != 'signed'"/>
                    <button name="action_confirm_delivery_received" string="Delivery Confirmed"
                        type="object"
                        invisible="state != 'delivered' or delivery_confirmed"/>
                    <button name="action_send_to_accountant" string="Send to Accountant"
                        type="object"
                        invisible="state not in ('signed', 'delivered')"/>
                    <button name="action_archive_employee" string="Archive Employee"
                        type="object" class="btn-warning"
                        invisible="state != 'delivered'"
                        confirm="This will deactivate the employee. Are you sure?"/>
                    <button name="action_cancel" string="Cancel"
                        type="object"
                        invisible="state not in ('draft', 'confirmed')"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,confirmed,signed,delivered,archived"/>
                </header>
                <sheet>
                    <group>
                        <group string="Termination">
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="company_id" readonly="1"/>
                            <field name="termination_type" readonly="state != 'draft'"/>
                            <field name="calc_method" readonly="state != 'draft'"
                                invisible="termination_type in ('fristlos', 'aufhebung')"/>
                            <field name="letter_date" readonly="state != 'draft'"/>
                            <field name="receipt_date" readonly="state != 'draft'"
                                invisible="calc_method != 'receipt' or termination_type in ('fristlos', 'aufhebung')"/>
                        </group>
                        <group string="Computed Dates">
                            <field name="employee_start_date"/>
                            <field name="tenure_years" widget="float" digits="[4,1]"/>
                            <field name="in_probation"/>
                            <field name="probation_end" invisible="not probation_end"/>
                            <field name="notice_period_text"/>
                            <field name="last_working_day"/>
                        </group>
                    </group>

                    <group string="Incident Details"
                        invisible="termination_type != 'fristlos'">
                        <group>
                            <field name="incident_date"/>
                            <field name="incident_overdue" invisible="not incident_overdue"/>
                        </group>
                        <group>
                            <field name="incident_description"/>
                        </group>
                    </group>

                    <group string="Agreement Details"
                        invisible="termination_type != 'aufhebung'">
                        <group>
                            <field name="include_severance"/>
                            <field name="severance_amount"
                                invisible="not include_severance"/>
                            <field name="garden_leave"/>
                        </group>
                        <group>
                            <field name="zeugnis_grade"/>
                        </group>
                    </group>

                    <group string="Resignation Details"
                        invisible="termination_type != 'bestaetigung'">
                        <group>
                            <field name="resignation_received_date"/>
                            <field name="resignation_method"/>
                            <field name="written_resignation_received"/>
                        </group>
                    </group>

                    <group string="Employee Address">
                        <group>
                            <field name="employee_street"/>
                            <field name="employee_zip"/>
                            <field name="employee_city"/>
                        </group>
                    </group>

                    <!-- Delivery tracking - visible after signing -->
                    <group string="Zustellung (Delivery)"
                        invisible="state in ('draft', 'confirmed')">
                        <group>
                            <field name="delivery_method"/>
                            <field name="delivery_date"/>
                            <field name="delivery_tracking_number"
                                invisible="delivery_method not in ('einschreiben_rueckschein', 'einwurf_einschreiben')"/>
                            <field name="delivery_witness"
                                invisible="delivery_method not in ('personal', 'bote')"/>
                        </group>
                        <group>
                            <field name="delivery_confirmed"/>
                            <field name="delivery_confirmed_date"
                                invisible="not delivery_confirmed"/>
                            <field name="delivery_proof_attachment_id"/>
                            <field name="delivery_notes"/>
                        </group>
                    </group>

                    <!-- Optional: Employee receipt confirmation -->
                    <group string="Empfangsbest&#228;tigung (optional)"
                        invisible="state in ('draft', 'confirmed')">
                        <group>
                            <field name="empfang_received"/>
                            <field name="empfang_date"
                                invisible="not empfang_received"/>
                            <field name="empfang_attachment_id"
                                invisible="not empfang_received"/>
                        </group>
                    </group>

                    <!-- Documents + Accountant -->
                    <group string="Documents"
                        invisible="state == 'draft'">
                        <group>
                            <field name="pdf_attachment_id"/>
                            <field name="signed_pdf_attachment_id"
                                invisible="not signed_pdf_attachment_id"/>
                            <field name="sign_request_id"/>
                        </group>
                        <group>
                            <field name="sent_to_accountant"/>
                            <field name="sent_to_accountant_date"
                                invisible="not sent_to_accountant"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="kw_termination_view_search" model="ir.ui.view">
        <field name="name">kw.termination.search</field>
        <field name="model">kw.termination</field>
        <field name="arch" type="xml">
            <search string="Terminations">
                <field name="employee_name"/>
                <field name="company_id"/>
                <field name="termination_type"/>
                <filter name="filter_draft" string="Draft"
                    domain="[('state', '=', 'draft')]"/>
                <filter name="filter_confirmed" string="Confirmed"
                    domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_signed" string="Signed"
                    domain="[('state', '=', 'signed')]"/>
                <filter name="filter_delivered" string="Delivered"
                    domain="[('state', '=', 'delivered')]"/>
                <filter name="filter_not_delivered" string="Not Yet Delivered"
                    domain="[('state', '=', 'signed'), ('delivery_method', '=', False)]"/>
                <separator/>
                <filter name="filter_not_sent" string="Not Sent to Accountant"
                    domain="[('sent_to_accountant', '=', False), ('state', 'not in', ('draft', 'cancelled'))]"/>
                <filter name="filter_delivery_unconfirmed" string="Delivery Unconfirmed"
                    domain="[('state', '=', 'delivered'), ('delivery_confirmed', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="groupby_type" string="Type"
                        context="{'group_by': 'termination_type'}"/>
                    <filter name="groupby_company" string="Company"
                        context="{'group_by': 'company_id'}"/>
                    <filter name="groupby_state" string="Status"
                        context="{'group_by': 'state'}"/>
                    <filter name="groupby_delivery" string="Delivery Method"
                        context="{'group_by': 'delivery_method'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_kw_termination" model="ir.actions.act_window">
        <field name="name">Terminations</field>
        <field name="res_model">kw.termination</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="kw_termination_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No terminations yet
            </p>
            <p>
                Use the Termination button on employee forms or create a new record.
            </p>
        </field>
    </record>
</odoo>
